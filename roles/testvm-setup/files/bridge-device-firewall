#!/bin/bash
# Allow traffic on bridge device interfaces through Qubes nftables.
#
# Qubes INPUT chain has policy drop; only iifgroup 2 (downstream VMs) get ICMP
# accepted. Bridge device eth0 is in group default, so we use custom-input.
# This script runs once per NM interface-up event.

IFACE="${DEVICE_IFACE:-$1}"
ACTION="$2"

[[ "$ACTION" == "up" ]] || exit 0
[[ -n "$IFACE" ]] || exit 0

# Only act on bridge-device-backed interfaces (static IP, no Qubes gateway).
PREFIX=$(ip -4 addr show dev "$IFACE" 2>/dev/null \
    | sed -n 's|.*inet \([0-9][0-9./]*\).*|\1|p' | head -1)
[[ -n "$PREFIX" ]] || exit 0

# Allow all IP traffic from bridge peers (same subnet) into this VM.
nft add rule ip qubes custom-input ip saddr "$PREFIX" accept 2>/dev/null || true
